# VetLens 环境变量配置

# 数据库路径（绝对路径或相对路径）
VETLENS_DB_PATH=./data/vetlens.db
# 数据目录（JSON 种子文件等），默认 ./data
DATA_DIR=./data

# OCR 引擎
PADDLE_OCR_URL=http://localhost:8866

# LLM 提供商 (claude-code | claude | openai | ollama | none)
# claude-code: 本地 Claude Code CLI（调用系统 claude 命令）
# claude:      Anthropic HTTP API（云端或本地端点）
# openai:      OpenAI 兼容接口（DeepSeek / 本地 LLM）
# ollama:      Ollama 本地模型
# none:        禁用 LLM（纯规则引擎）
LLM_PROVIDER=none

# ── Claude Code CLI ──
# CLAUDE_CLI_PATH 留空则自动在 PATH 中搜索 claude 命令
# CLAUDE_CLI_PATH=C:\Users\<user>\AppData\Local\npm-cache\claude.cmd

# ── Claude HTTP API ──
ANTHROPIC_API_KEY=
# 云端: https://api.anthropic.com
# 本地: http://localhost:8080（无 API key 也可用）
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Ollama 本地 ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── OpenAI 兼容 ──
OPENAI_API_KEY=
# DeepSeek: https://api.deepseek.com（model: deepseek-chat）
# 本地 LLM: http://localhost:1234/v1（LM Studio / vLLM 等）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 数据回收端
VETLENS_CONTRIBUTE_URL=https://api.vetlens.app/api/contribute

# ── 豆包 API（OCR 提取专用，速度快） ──
# 火山引擎豆包 API，OpenAI 兼容接口
# DOUBAO_API_KEY=your-api-key
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL=doubao-seed-1-6-251015

# 服务端口
PORT=3000

# PetVault 报告配置 (pet-vault-skill)
# Python 解释器路径（留空自动探测）
PYTHON_PATH=C:\Python313\python.exe
# 本地资料库和报告输出目录
PETVAULT_VAULT_DIR=~/PetVault/vault
PETVAULT_REPORTS_DIR=~/PetVault/reports
# LaTeX 引擎 (xelatex / latexmk / none)
PETVAULT_TEX_ENGINE=none
