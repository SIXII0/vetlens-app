# VetLens 环境变量配置

# 数据库路径
VETLENS_DB_PATH=./data/vetlens.db

# OCR 引擎
PADDLE_OCR_URL=http://localhost:8866

# LLM 提供商 (none | claude | ollama | openai)
LLM_PROVIDER=none

# Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama 本地
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI 兼容
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 数据回收端
VETLENS_CONTRIBUTE_URL=https://api.vetlens.app/api/contribute

# 服务端口
PORT=3000
