{
  "name": "vetlens-app",
  "version": "0.1.0",
  "description": "VetLens（宠医透镜）—— 宠物医疗账单解读与保险预检应用",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "ocr": "python ocr_server/server.py",
    "dev:all": "concurrently -n web,ocr -c blue,green \"npm run dev\" \"npm run ocr\"",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.4.7",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
